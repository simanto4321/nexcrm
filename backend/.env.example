# PostgreSQL (Supabase) — use postgresql+psycopg:// for psycopg v3 driver
DATABASE_URL=postgresql+psycopg://user:password@host:5432/postgres

JWT_SECRET=change-me-to-a-long-random-secret-key
JWT_EXPIRE_MINUTES=1440

# Ollama — local open-source LLM (free, unlimited, runs on your PC)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TIMEOUT_SECONDS=120

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
GMAIL_ADDRESS=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Optional demo mode (no Gmail needed): run scripts/run-demo-smtp.ps1 first
EMAIL_DEMO_MODE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
CORS_ORIGINS=http://localhost:5173,http://localhost:8081
